// Tiny profile to validate wiring end to end, e.g.:
//   cd nextflow && nextflow run . -stub -profile test
// (-stub skips real execution; drop it to run for real inside the container.)
params {
    input      = "${projectDir}/assets/samplesheet_test.csv"
    batch_size = 2
    sets       = 'aa carbon'
    outdir     = 'results_test'
}

// Tiny resource requests so the wiring can be validated on a laptop / CI runner.
process {
    withLabel: process_low    { cpus = 1 ; memory = 1.GB ; time = 1.h }
    withLabel: process_medium { cpus = 1 ; memory = 1.GB ; time = 1.h }
}
