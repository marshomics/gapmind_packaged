// GapMind (Nextflow + Singularity) configuration.

manifest {
    name            = 'gapmind-nf'
    author          = 'derived from morgannprice/PaperBLAST (GapMind)'
    description      = 'GapMind amino-acid + carbon pathway analysis at scale'
    mainScript       = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version         = '1.0.0'
}

params {
    // I/O
    input             = null                                    // samplesheet CSV: sample,faa
    outdir            = 'results'

    // analysis
    sets              = 'aa carbon'
    batch_size        = 500
    search_tool       = 'diamond'                              // diamond | usearch
    knownsim          = true                                   // amino-acid known-gap step (needs usearch)

    // databases
    db_dir            = null                                    // reuse an existing db dir; else download
    prebuilt_base     = 'https://papers.genomics.lbl.gov/tmp'

    // downstream tables / figures
    pa_mode           = 'probably'                             // probably | strict
    keep_cand         = true                                   // keep the large *.sum.cand table

    // containers
    container         = 'gapmind:latest'                       // docker image tag
    singularity_image = "${projectDir}/containers/gapmind.sif" // used by -profile singularity

    help              = false
}

// Default per-process resources (override per site with a profile / -c file).
process {
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
    maxRetries    = 2
    container     = params.container

    withLabel: process_low    { cpus = 2 ; memory = 6.GB  ; time = 4.h  }
    withLabel: process_medium { cpus = 8 ; memory = 24.GB ; time = 12.h }
}

profiles {

    local {
        process.executor = 'local'
    }

    // Sun Grid Engine. cpus -> "-pe parallel N" via penv; queue -> "-q".
    // Memory/walltime -> scheduler flags can be site-specific; if they aren't
    // honored automatically, uncomment clusterOptions and adjust for your site.
    sge {
        process.executor = 'sge'
        process.penv     = 'parallel'
        process.queue    = 'standard.q'
        // process.clusterOptions = { "-l h_vmem=${task.memory.toGiga()}G -l h_rt=${task.time.toSeconds() as long}" }
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'standard'
        // memory -> --mem, cpus -> --cpus-per-task, time -> --time are automatic.
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = params.singularity_image
    }

    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        process.container    = params.singularity_image
    }

    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    test { includeConfig 'conf/test.config' }
}

// Reports (handy provenance for a shared resource).
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt";     overwrite = true }
